import os

for sdk_target in MMSPlugin.sdk_targets:
    sdk = sdk_target.sdk
    cxx = sdk_target.cxx

    binary = MMSPlugin.HL2Library(
        builder, cxx, f'{MMSPlugin.metadata["name"]}.{sdk["name"]}', sdk
    )

    binary.sources += [
        "src/cs2menus.cpp",
        "src/bridge/capi.cpp",
        "src/config/config.cpp",
        "src/entity/schema.cpp",
        "src/lang/translations.cpp",
        "src/menu/menu_manager.cpp",
        "src/render/center_html.cpp",
        "src/sigscan/module.cpp",
        "src/utils/print_utils.cpp",
    ]

    binary.custom = [
        builder.tools.Protoc(
            protoc=sdk_target.protoc,
            sources=[
                os.path.join(sdk["path"], "common", "network_connection.proto"),
                os.path.join(sdk["path"], "common", "networkbasetypes.proto"),
                os.path.join(sdk["path"], "game", "shared", "usermessages.proto"),
                os.path.join(sdk["path"], "game", "shared", "gameevents.proto"),
            ],
        )
    ]

    nodes = builder.Add(binary)
    MMSPlugin.binaries += [nodes]
