<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<LangVersion>latest</LangVersion>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<AssemblyName>CounterStrikeSharp.Cs2Menus</AssemblyName>
		<RootNamespace>Cs2Menus</RootNamespace>
	</PropertyGroup>

	<ItemGroup>
		<!-- Framework-agnostic core. -->
		<Compile Include="../../src/Cs2MenusNative.cs" Link="Cs2MenusNative.cs" />
		<Compile Include="../../src/Cs2Menus.cs" Link="Cs2Menus.cs" />
	</ItemGroup>

	<ItemGroup>
		<!-- For Server.GameDirectory in LoadDefault. The host provides it at runtime. -->
		<PackageReference Include="CounterStrikeSharp.API" Version="*" ExcludeAssets="runtime"
			PrivateAssets="all" />
	</ItemGroup>

</Project>
